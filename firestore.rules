rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{scoreId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
          "name",
          "score",
          "level",
          "cause",
          "uid",
          "createdAt"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 16
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 999999
        && request.resource.data.level is int
        && request.resource.data.level >= 1
        && request.resource.data.level <= 999
        && request.resource.data.cause is string
        && request.resource.data.cause.size() <= 40
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
